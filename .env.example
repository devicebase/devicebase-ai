# LLM Configuration (Required)
OPENAI_API_KEY=your-api-key-here

# LLM Configuration (Optional - with provider-specific defaults)
# For OpenAI
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_NAME=gpt-4o-mini

# For Azure OpenAI
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# OPENAI_MODEL_NAME=gpt-4o

# For Anthropic (via compatible proxy)
# OPENAI_BASE_URL=https://api.anthropic.com/v1
# OPENAI_MODEL_NAME=claude-3-5-sonnet-20241022

# For local models (Ollama, vLLM, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL_NAME=llama3.2

# Devicebase Configuration (Optional)
# DEVICEBASE_BASE_URL=http://localhost:8080
# DEVICEBASE_API_KEY=your-devicebase-key-here
# DEVICEBASE_DEVICE_SERIAL=your-devicebase-device-serial-here